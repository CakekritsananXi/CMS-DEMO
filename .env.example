# ContentFlow Environment Configuration
# Copy this file to .env.local and update the values for your environment

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application name displayed in the browser title and navigation
VITE_APP_NAME=ContentFlow

# Application version (automatically set during build)
VITE_APP_VERSION=1.0.0

# Environment type - affects logging, error handling, and feature flags
# Options: development, staging, production
VITE_ENVIRONMENT=development

# Base URL for the application (useful for subdirectory deployments)
# Default: / (root)
# Example: /contentflow/ for subdirectory deployment
VITE_BASE_URL=/

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API base URL
# Development: http://localhost:3001
# Staging: https://api-staging.contentflow.com
# Production: https://api.contentflow.com
VITE_API_URL=http://localhost:3001

# API version for versioned endpoints
VITE_API_VERSION=v1

# API timeout in milliseconds
VITE_API_TIMEOUT=10000

# Enable API request/response logging (development only)
VITE_API_DEBUG=true

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT token storage key (used in localStorage)
VITE_AUTH_TOKEN_KEY=contentflow_auth_token

# Session timeout in minutes
VITE_SESSION_TIMEOUT=60

# Enable biometric authentication (if supported by device)
VITE_ENABLE_BIOMETRIC_AUTH=true

# Password requirements
VITE_PASSWORD_MIN_LENGTH=8
VITE_PASSWORD_REQUIRE_SPECIAL_CHARS=true

# =============================================================================
# SUPABASE CONFIGURATION (if using Supabase)
# =============================================================================

# Supabase project URL
# Get this from your Supabase project dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (public key)
# Get this from your Supabase project dashboard
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Enable Supabase real-time features
VITE_SUPABASE_REALTIME=true

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Sentry DSN for error tracking
# Get this from your Sentry project settings
VITE_SENTRY_DSN=

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# Sentry environment name
VITE_SENTRY_ENVIRONMENT=development

# Sample rate for performance monitoring (0.0 to 1.0)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable experimental features
VITE_ENABLE_EXPERIMENTAL_FEATURES=false

# Enable AI-powered content suggestions
VITE_ENABLE_AI_SUGGESTIONS=false

# Enable advanced analytics dashboard
VITE_ENABLE_ADVANCED_ANALYTICS=true

# Enable team collaboration features
VITE_ENABLE_COLLABORATION=true

# Enable content library management
VITE_ENABLE_CONTENT_LIBRARY=true

# Enable calendar drag-and-drop functionality
VITE_ENABLE_CALENDAR_DND=true

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# OpenAI API key for AI features (if enabled)
VITE_OPENAI_API_KEY=

# Unsplash API key for stock photos
VITE_UNSPLASH_ACCESS_KEY=

# Stripe publishable key for payment processing
VITE_STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable React DevTools in production (not recommended)
VITE_ENABLE_REACT_DEVTOOLS=false

# Enable Redux DevTools (if using Redux)
VITE_ENABLE_REDUX_DEVTOOLS=true

# Mock API responses (useful for development without backend)
VITE_MOCK_API=false

# Enable hot module replacement debug logs
VITE_HMR_DEBUG=false

# =============================================================================
# CONTENT & MEDIA CONFIGURATION
# =============================================================================

# Maximum file upload size in MB
VITE_MAX_FILE_SIZE=10

# Allowed file types for uploads (comma-separated)
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,docx,xlsx,pptx

# CDN base URL for media assets
VITE_CDN_URL=

# Enable image optimization
VITE_ENABLE_IMAGE_OPTIMIZATION=true

# =============================================================================
# LOCALIZATION
# =============================================================================

# Default application language
VITE_DEFAULT_LANGUAGE=en

# Available languages (comma-separated)
VITE_AVAILABLE_LANGUAGES=en,es,fr,de

# Enable right-to-left (RTL) support
VITE_ENABLE_RTL=false

# =============================================================================
# PERFORMANCE & CACHING
# =============================================================================

# Enable service worker for offline functionality
VITE_ENABLE_SERVICE_WORKER=true

# Cache duration for API responses in minutes
VITE_API_CACHE_DURATION=5

# Enable lazy loading for images
VITE_ENABLE_LAZY_LOADING=true

# Debounce delay for search inputs in milliseconds
VITE_SEARCH_DEBOUNCE_DELAY=300

# =============================================================================
# SECURITY HEADERS & POLICIES
# =============================================================================

# Content Security Policy (CSP) nonce
VITE_CSP_NONCE=

# Enable HTTPS redirect in production
VITE_FORCE_HTTPS=true

# Allowed domains for external resources
VITE_ALLOWED_DOMAINS=contentflow.com,api.contentflow.com

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Build output directory
VITE_BUILD_DIR=dist

# Enable source maps in production
VITE_GENERATE_SOURCEMAP=false

# Enable bundle analyzer
VITE_ANALYZE_BUNDLE=false

# Deployment target (affects build optimizations)
# Options: web, electron, mobile
VITE_DEPLOYMENT_TARGET=web

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (error, warn, info, debug)
VITE_LOG_LEVEL=info

# Enable console logging in production
VITE_ENABLE_CONSOLE_LOGS=false

# Log API requests and responses
VITE_LOG_API_CALLS=true

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Enable test mode (affects certain behaviors)
VITE_TEST_MODE=false

# Mock user authentication in tests
VITE_MOCK_AUTH=false

# Test database URL (if different from development)
VITE_TEST_DB_URL=

# =============================================================================
# NOTES & SECURITY CONSIDERATIONS
# =============================================================================

# IMPORTANT SECURITY NOTES:
# 1. Never commit actual API keys or secrets to version control
# 2. Use different keys for development, staging, and production
# 3. Regularly rotate API keys and tokens
# 4. Ensure HTTPS is enabled in production
# 5. Validate all environment variables at application startup

# VARIABLE NAMING CONVENTION:
# - All Vite environment variables must start with VITE_
# - Use UPPER_SNAKE_CASE for consistency
# - Group related variables together
# - Include comments explaining the purpose and format

# VALIDATION:
# The application should validate all required environment variables
# at startup and provide clear error messages for missing or invalid values.

# EXAMPLES:
# Development: Copy this file to .env.local and set development values
# Staging: Use .env.staging with staging-specific values
# Production: Set environment variables directly in your hosting platform