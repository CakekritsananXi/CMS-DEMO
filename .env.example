# OWASP ZAP Configuration (Optional)
# If you have OWASP ZAP running with API access, you can configure it here

# ZAP API Key (optional, for authenticated API access)
VITE_ZAP_API_KEY=your-zap-api-key-here

# ZAP Base URL (optional, defaults to http://localhost:8080)
VITE_ZAP_BASE_URL=http://localhost:8080

# Security Scanning Configuration
VITE_SECURITY_WEBHOOK_URL=https://hooks.slack.com/your-webhook
VITE_SECURITY_EMAIL_NOTIFICATIONS=true

# Note: The security audit tool works in demo mode without these variables
# To use with real OWASP ZAP:
# 1. Install and run OWASP ZAP
# 2. Enable API access in ZAP
# 3. Configure the API key and URL above
# 4. The tool will automatically detect and connect to ZAP
